# Lore root-level docker compose config

# Database
POSTGRES_DB=lore
POSTGRES_USER=lore
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://lore:change-me@postgres:5432/lore

# Next.js app
API_TOKEN=your-token-if-needed
WEB_PORT=18901
# Boot is fixed server-side to core://agent, core://soul, preferences://user

# Backend-owned retrieval config
LORE_EMBEDDING_PROVIDER=openai_compatible
LORE_EMBEDDING_BASE_URL=http://127.0.0.1:8090/v1
LORE_EMBEDDING_API_KEY=change-me
LORE_EMBEDDING_MODEL=text-embedding-3-small
LORE_VIEW_LLM_PROVIDER=openai_compatible
LORE_VIEW_LLM_BASE_URL=http://127.0.0.1:8090/v1
LORE_VIEW_LLM_API_KEY=change-me
LORE_VIEW_LLM_MODEL=deepseek-v4-flash
LORE_VIEW_LLM_TIMEOUT_MS=30000
LORE_VIEW_LLM_API_VERSION=
LORE_VIEW_LLM_MAX_DOCS_PER_RUN=4

# Optional image overrides
LORE_POSTGRES_IMAGE=fffattiger/pgvector-zhparser:pg16
LORE_FRONTEND_IMAGE=fffattiger/lore:latest
