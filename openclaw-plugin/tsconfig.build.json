{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "dist",
    "declaration": false,
    "sourceMap": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["index.ts", "api.ts", "tools.ts", "hooks.ts", "uri.ts", "formatters.ts"],
  "exclude": ["dist", "__tests__", "node_modules"]
}
