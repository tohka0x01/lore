DATABASE_URL=postgresql://lore:change-me@127.0.0.1:5432/lore
API_TOKEN=

# Optional Redis cache backend. If unset or unreachable at startup, Lore uses local LRU cache.
# Cache itself is enabled/disabled from the Lore settings page; default is enabled.
REDIS_URL=redis://redis:6379/0
CACHE_KEY_PREFIX=lore
CACHE_LOCAL_MAX_ITEMS=2000
