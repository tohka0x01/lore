{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx ${CLAUDE_PLUGIN_ROOT}/hooks/rules-inject.ts",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "LORE_BASE_URL=${LORE_BASE_URL:-http://127.0.0.1:18901} npx tsx ${CLAUDE_PLUGIN_ROOT}/hooks/recall-inject.ts",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
